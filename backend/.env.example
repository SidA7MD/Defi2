# ─────────────────────────────────────────────
#  IHSAN Platform — Environment Configuration
#  Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/ihsan_db?schema=public"

# JWT Secrets — MUST change in production (minimum 32 characters)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated for multi-origin
# Example: http://localhost:3000,https://ihsan.example.com
CORS_ORIGIN=http://localhost:3000

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Rate Limiting (per 15-minute window)
RATE_LIMIT_AUTH=10
RATE_LIMIT_API=200

# Blockchain (optional — set to true to enable blockchain anchoring)
BLOCKCHAIN_ENABLED=false
ETHEREUM_RPC_URL=
CONTRACT_ADDRESS=
